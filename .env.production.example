APP_NAME=Laravel-nginx-uds
APP_ENV=production
APP_DEBUG=false
APP_KEY=<generate_with_key_generate>
APP_URL=http://localhost
APP_BASE_PATH=/var/www/laravel
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Локальный порт для `make up-prod`
NGINX_PORT=8050

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=laravel-postgres-nginx-uds
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=postgres
DB_PASSWORD=password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=laravel-redis-nginx-uds
REDIS_PORT=6379
REDIS_PASSWORD=3179019
